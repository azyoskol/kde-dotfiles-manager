# Documentation files are source content - no need to ignore them
# The added files (docs/*.md) and modified file (README.md) are documentation/source files
# No build artifacts, dependencies, or temporary files detected in changes

# Dependencies
vendor/

# Logs and temp files
*.log
*.tmp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage
coverage/
htmlcov/
.coverage

# Backup and temporary directories
backup_*/
temp_*/
*.bak
*.tmp
